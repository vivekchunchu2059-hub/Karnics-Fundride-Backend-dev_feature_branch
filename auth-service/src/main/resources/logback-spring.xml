<?xml version="1.0" encoding="UTF-8"?>

<configuration>
    <!-- Log Folder -->
    <!-- ./logs under module root; ./auth-service/logs doubled the folder when cwd was already auth-service -->
    <property name="LOG_PATH" value="./logs"/>

    <!-- Console Logs -->
    <appender name="CONSOLE"
              class="ch.qos.logback.core.ConsoleAppender">

        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n
            </pattern>
        </encoder>
    </appender>

    <!-- Daily File Logs -->
    <appender name="FILE"
              class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy
                class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">

            <!-- Daily Log File -->
            <fileNamePattern>
                ${LOG_PATH}/auth-service-%d{yyyy-MM-dd}.log
            </fileNamePattern>

            <!-- Keep 30 Days -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>

        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n
            </pattern>
        </encoder>
    </appender>
    <!-- Root Logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>